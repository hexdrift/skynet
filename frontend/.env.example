# Skynet Frontend Configuration
# Copy to .env.local: cp .env.example .env.local

# Backend API URL
# ⚠️  Use HTTPS in production to protect API keys and auth tokens!
# TODO: On-premise — set to your internal backend hostname.
# Development:
# Still respected as a build-time default; `API_URL` (set on the running
# pod, see runtime section below) takes precedence in production images.
NEXT_PUBLIC_API_URL=http://localhost:8000
# Production example:
# NEXT_PUBLIC_API_URL=https://api.skynet.yourcompany.com

# Public site origin — inlined into robots.txt, sitemap.xml, OpenGraph and
# canonical URLs at build time.
# TODO: On-premise — set to your internal frontend origin at BUILD time. It is
# inlined into robots/sitemap/OG/canonical and cannot be changed on a prebuilt
# image; when unset it defaults to the public https://skynet.app.
# NEXT_PUBLIC_SITE_URL=https://skynet.yourcompany.com

# ── Runtime env (server-side, runtime-overridable per pod) ──
# These values are read by the Next.js server at request time and injected
# into `window.__SKYNET_ENV__` so a single built image can be pointed at
# any backend by setting these env vars on the pod (no rebuild needed).
# When unset, the build-time `NEXT_PUBLIC_*` defaults above are used.
API_URL=http://localhost:8000
APP_VERSION=0.1.0

# ── NextAuth ──
# TODO: On-premise — generate a fresh secret: openssl rand -base64 32
AUTH_SECRET=change-me-in-production
# Shared with the backend. Generate a separate strong value and set the same
# value in the backend environment so admin API calls can be verified.
BACKEND_AUTH_SECRET=change-me-in-production

# ── On-prem SSO (ADFS / Entra ID / Okta / any OIDC provider) ──
# When set, users auto-redirect to SSO and the hosted providers below are not
# offered. Leave unset for the hosted setup (social + email/password).
#
# TODO: On-premise — point at your internal IdP.
#
# ADFS:     AUTH_SSO_ISSUER=https://adfs.yourcompany.com/adfs
# Entra ID: AUTH_SSO_ISSUER=https://login.microsoftonline.com/{tenant-id}/v2.0
# Okta:     AUTH_SSO_ISSUER=https://yourcompany.okta.com
# Keycloak: AUTH_SSO_ISSUER=https://keycloak.yourcompany.com/realms/skynet
#
# AUTH_SSO_ISSUER=
# AUTH_SSO_CLIENT_ID=
# AUTH_SSO_CLIENT_SECRET=
# AUTH_SSO_SCOPE=openid profile email groups
# AUTH_GROUP_CLAIM=groups
# AUTH_ADMIN_GROUPS=Skynet Admins,Platform Ops
# AUTH_ADMINS=break-glass-admin@your-company.com

# ── Hosted sign-in (social + email/password) ──
# Used when SSO above is unset. Each social provider appears on the login screen
# only when BOTH its id and secret are set; email/password ("create an account
# in Skynet") always works and is verified by the backend over BACKEND_AUTH_SECRET.
# Identity is the email for every provider. AUTH_ADMINS (above) grants the admin
# role to those emails on any provider. See AUTH_SETUP.md for step-by-step OAuth
# app creation and the exact redirect URIs to register.
#
# Google — https://console.cloud.google.com  (APIs & Services → Credentials)
#   Authorized redirect URI: http://localhost:3000/api/auth/callback/google
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
#
# GitHub — https://github.com/settings/developers  (New OAuth App)
#   Authorization callback URL: http://localhost:3000/api/auth/callback/github
# AUTH_GITHUB_ID=
# AUTH_GITHUB_SECRET=

# TODO: On-premise — if your IdP uses a self-signed cert, point Node at your
# internal CA bundle so the OIDC handshake succeeds.
# NODE_EXTRA_CA_CERTS=/etc/ssl/certs/internal-ca-bundle.pem

# Set DEV_AUTH=false to disable login entirely (open access)
# DEV_AUTH=false

# ── Feature flags ──
# Generalist agent panel (Cmd/Ctrl+J). Unset: on in dev, off in prod.
# Accepts: 1, true, on, yes
# NEXT_PUBLIC_FEATURE_GENERALIST_AGENT=1
