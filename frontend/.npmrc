# TODO: On-premise — point npm at an internal registry mirror.
# Uncomment and replace with your Artifactory / Nexus / Verdaccio URL:
#
#   registry=https://artifactory.your-company.com/api/npm/npm-remote/
#   //artifactory.your-company.com/api/npm/npm-remote/:_authToken=${NPM_TOKEN}
#   strict-ssl=true
#   cafile=/etc/ssl/certs/internal-ca-bundle.pem
#
# For build-time auth, pass NPM_TOKEN via --build-arg or a Docker secret.
