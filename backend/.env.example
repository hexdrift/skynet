# ════════════════════════════════════════════
# Skynet Backend Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ════════════════════════════════════════════

# ── LLM API Keys ──
# Required: At least one LLM provider key
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# FIREWORKS_AI_API_KEY=your-fireworks-api-key-here

# ── Database (PostgreSQL) ──
# Local PostgreSQL:
REMOTE_DB_URL=postgresql://your-user@localhost:5432/skynet

# Remote PostgreSQL (e.g., Supabase, RDS):
# REMOTE_DB_URL=postgresql://user:password@host:5432/dbname

# ── Server ──
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── CORS ──
# Comma-separated list of allowed origins (defaults to localhost:3000,3001)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# ── Worker ──
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL=2.0
WORKER_STALE_THRESHOLD=600

# ── Agent models ──
# LiteLLM model id used by the submit-wizard code agent.
# CODE_AGENT_MODEL=openai/gpt-4o-mini
# CODE_AGENT_BASE_URL=

# LiteLLM model id used by the generalist agent (Cmd/Ctrl+J panel).
# Default is Fireworks-hosted MiniMax — it emits <think> reasoning that
# streams visibly to the chat UI. OpenAI gpt-5.x / o-series models also work
# but hide their chain of thought, so the "thinking" indicator won't populate.
# GENERALIST_AGENT_MODEL=fireworks_ai/accounts/fireworks/models/minimax-m2p7
# GENERALIST_AGENT_BASE_URL=

# ── Notifications (internal comms) ──
# Webhook URL for your messaging platform (Rocket.Chat, Slack, Teams, etc.)
# COMMS_WEBHOOK_URL=https://chat.yourcompany.com/hooks/your-webhook-id
# COMMS_CHANNEL=#skynet-notifications
# FRONTEND_URL=https://skynet.yourcompany.com
