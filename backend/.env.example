# ════════════════════════════════════════════
# Skynet Backend Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# Air-gap operators: see AIRGAP.md.
# ════════════════════════════════════════════

# ── LLM gateway (required) ──
# Skynet talks to one OpenAI-compatible endpoint for every LLM call. Point
# OPENAI_API_BASE at it and set OPENAI_API_KEY to whatever token the gateway
# expects (any non-empty string for endpoints that don't authenticate
# per-user). On-prem deployments must use an internal LiteLLM / vLLM /
# Ollama / Azure-on-prem endpoint here — leaving it pointed at api.openai.com
# will fail the moment egress is blocked.
OPENAI_API_BASE=https://llm.your-company.com/v1
OPENAI_API_KEY=replace-me

# ── Public-cloud providers (internet-only, optional) ──
# Uncomment only when running outside an air-gapped environment.
# OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# FIREWORKS_AI_API_KEY=your-fireworks-api-key-here

# ── Database (PostgreSQL, must have pgvector) ──
REMOTE_DB_URL=postgresql://skynet:replace-me@localhost:5432/skynet
# Used by docker-compose to seed the bundled Postgres container. Pick a
# strong value for any non-local stack — compose now requires it explicitly.
POSTGRES_PASSWORD=replace-me

# ── Server ──
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── CORS ──
# Comma-separated list of allowed origins (defaults to localhost:3000,3001)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# ── Worker ──
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL=2.0
WORKER_STALE_THRESHOLD=600

# ── Per-user quota ──
# Default cap for users without a live DB override. Admins can update
# individual users from the settings modal without a backend restart.
MAX_JOBS_PER_USER=100
# Shared with the frontend. Required for backend verification of admin UI calls.
BACKEND_AUTH_SECRET=change-me-in-production
# Prefer IdP groups for admins. ADMIN_USERNAMES is break-glass only.
# ADMIN_GROUPS=Skynet Admins,Platform Ops
# ADMIN_USERNAMES=bob@example.com,ops@example.com
# QUOTA_OVERRIDES={"legacy_power_user":500,"legacy_unlimited":null}

# ── Agent models ──
# Both agents (code agent and generalist agent) default to MINIMAX_MODEL_ID
# in core/config.py — currently the Fireworks-hosted MiniMax M2p7. MiniMax
# emits <think> reasoning that streams visibly to the chat UI; OpenAI gpt-5.x
# / o-series models also work but hide their chain of thought, so the
# "thinking" indicator won't populate.
#
# On-prem: override BOTH the model id (your internal LiteLLM tag for MiniMax
# 2.7) and the base URL (your internal OpenAI-compatible gateway) for each
# agent. The Fireworks default needs egress to api.fireworks.ai.
# CODE_AGENT_MODEL=openai/minimax-m2p7
# CODE_AGENT_BASE_URL=https://llm.your-company.com/v1
# GENERALIST_AGENT_MODEL=openai/minimax-m2p7
# GENERALIST_AGENT_BASE_URL=https://llm.your-company.com/v1

# ── Embedding pipeline (explore-map projection) ──
# Each successful job is summarised + embedded; the public /explore scatter
# is the only consumer. Point at an internal OpenAI-compatible embedding API.
# The backend sends POST {EMBEDDINGS_BASE_URL}/embeddings with {model, input}.
# If EMBEDDINGS_API_KEY is unset, OPENAI_API_KEY is reused.
# EMBEDDINGS_BASE_URL=https://llm.your-company.com/v1
# EMBEDDINGS_MODEL=jina-code-embeddings-0.5b
# EMBEDDINGS_API_KEY=
# Or disable the pipeline entirely (existing rows still render):
# EMBEDDINGS_ENABLED=false

# ── Notifications (internal comms, optional) ──
# Point at internal Rocket.Chat / Mattermost webhook, or leave unset to
# disable notifications entirely.
# COMMS_WEBHOOK_URL=https://chat.yourcompany.com/hooks/your-webhook-id
# COMMS_CHANNEL=#skynet-notifications
# FRONTEND_URL=https://skynet.yourcompany.com
