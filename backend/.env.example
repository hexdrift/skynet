# ════════════════════════════════════════════
# Skynet Backend Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ════════════════════════════════════════════

# ── LLM API Keys ──
# Required: At least one LLM provider key
# TODO: On-premise — leave public-provider keys unset; rely on an internal
# OpenAI-compatible gateway (vLLM / Ollama / Azure-on-prem) configured via
# the *_BASE_URL vars below. Public keys here would cause egress attempts.
OPENAI_API_KEY=sk-your-openai-key-here
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# FIREWORKS_AI_API_KEY=your-fireworks-api-key-here

# ── Database (PostgreSQL) ──
# TODO: On-premise — point at internal Postgres (must have pgvector extension).
# Local PostgreSQL:
REMOTE_DB_URL=postgresql://your-user@localhost:5432/skynet

# Remote PostgreSQL (e.g., Supabase, RDS):
# REMOTE_DB_URL=postgresql://user:password@host:5432/dbname

# ── Server ──
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# ── CORS ──
# Comma-separated list of allowed origins (defaults to localhost:3000,3001)
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://yourdomain.com

# ── Worker ──
WORKER_CONCURRENCY=2
WORKER_POLL_INTERVAL=2.0
WORKER_STALE_THRESHOLD=600

# ── Agent models ──
# Both agents (code agent and generalist agent) default to MINIMAX_MODEL_ID
# in core/config.py — currently Fireworks-hosted MiniMax M2p7. MiniMax emits
# <think> reasoning that streams visibly to the chat UI; OpenAI gpt-5.x /
# o-series models also work but hide their chain of thought, so the
# "thinking" indicator won't populate.
#
# TODO: On-premise — override BOTH model id (your internal LiteLLM tag for
# MiniMax 2.7) and base URL (your internal OpenAI-compatible gateway) for
# each agent. The Fireworks default needs egress to api.fireworks.ai.
# CODE_AGENT_MODEL=openai/minimax-m2p7
# CODE_AGENT_BASE_URL=https://llm.your-company.com/v1
# GENERALIST_AGENT_MODEL=openai/minimax-m2p7
# GENERALIST_AGENT_BASE_URL=https://llm.your-company.com/v1

# ── Recommendations (semantic similarity feature) ──
# The embedder model is vendored under backend/vendor/models/ and tracked via
# git-lfs, so the default works air-gapped with no extra setup. Make sure
# `git lfs pull` has run before starting the backend.
# Override only if you want to swap models or load from a different path:
# RECOMMENDATIONS_EMBEDDING_MODEL=/abs/path/to/your/embedder
# Or disable the feature entirely:
# RECOMMENDATIONS_ENABLED=false

# ── Notifications (internal comms) ──
# TODO: On-premise — point at internal Rocket.Chat / Mattermost webhook,
# or leave unset to disable notifications entirely.
# COMMS_WEBHOOK_URL=https://chat.yourcompany.com/hooks/your-webhook-id
# COMMS_CHANNEL=#skynet-notifications
# FRONTEND_URL=https://skynet.yourcompany.com
