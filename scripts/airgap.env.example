# ─────────────────────────────────────────────────────────────────────────────
# Skynet air-gap install worksheet
#
# Carry this file across the gap with the release bundle. Inside the air-gapped
# network, copy it and fill in every <<FILL: ...>> below in a plain text editor
# (no internet, no extra tooling needed), then drive the install with it:
#
#     cp scripts/airgap.env.example airgap.env     # then edit airgap.env
#     source airgap.env
#     scripts/airgap_migrate.sh values             # writes the Helm values file
#     scripts/airgap_migrate.sh render             # helm lint + template (review)
#     scripts/airgap_migrate.sh install            # helm upgrade --install
#     scripts/airgap_migrate.sh status             # rollout + smoke commands
#
# Every value here is consumed by scripts/airgap_migrate.sh. Lines left at their
# placeholder produce obviously-wrong hostnames/CIDRs so a forgotten field fails
# loudly at render/install rather than silently. See AIRGAP.html for the full
# explanation of each setting.
#
# Topology this worksheet assumes (change in the chart if yours differs):
#   • OpenShift Routes   • external managed pgvector   • images carried in as tars
# ─────────────────────────────────────────────────────────────────────────────

# ── Release ──────────────────────────────────────────────────────────────────
export RELEASE="skynet"
export NAMESPACE="skynet"

# ── Images & internal registry ───────────────────────────────────────────────
# REGISTRY is your internal registry + project. After `docker load`, the backend
# and frontend tags must be REGISTRY/BACKEND_REPOSITORY:IMAGE_TAG.
export REGISTRY="<<FILL: e.g. artifactory.corp.internal/skynet>>"
export IMAGE_TAG="<<FILL: e.g. 2026.06.23>>"
export PULL_SECRET="<<FILL: docker-registry pull Secret name, e.g. artifactory-pull-secret>>"
export BACKEND_REPOSITORY="skynet/backend"
export FRONTEND_REPOSITORY="skynet/frontend"

# ── Public routes (OpenShift) ────────────────────────────────────────────────
export FRONTEND_HOST="<<FILL: e.g. skynet.apps.cluster.internal>>"
export BACKEND_HOST="<<FILL: e.g. skynet-api.apps.cluster.internal>>"

# ── Identity (ADFS / OIDC) ───────────────────────────────────────────────────
export OIDC_ISSUER="<<FILL: e.g. https://adfs.corp.internal/adfs>>"
export OIDC_CLIENT_ID="<<FILL: e.g. skynet>>"
export OIDC_SCOPE="openid profile email groups"
export AUTH_GROUP_CLAIM="groups"
# IdP group(s) that grant admin; AUTH_ADMINS is the break-glass named-user path.
export AUTH_ADMIN_GROUPS="<<FILL: e.g. Skynet-Admins>>"
export AUTH_ADMINS="<<FILL: e.g. break-glass-admin@corp.internal>>"

# ── Internal LLM gateway + embeddings (OpenAI-compatible) ────────────────────
# The *_MODEL ids are forwarded verbatim to the gateway — they must match models
# it actually serves (the gpt-5 placeholder will 404 on most gateways).
# Explore search backend — also decides which Postgres extension you need:
#   lexical  (default) = vanilla Postgres, no extension (leave as-is if unsure).
#   bm25     = needs the pg_search extension.
#   semantic = needs pgvector + the EMBEDDING_* gateway below.
export SEARCH_BACKEND="lexical"
export LLM_BASE_URL="<<FILL: e.g. https://llm-gateway.corp.internal/v1>>"
export CODE_AGENT_MODEL="<<FILL: model id your gateway serves, e.g. openai/qwen2.5-coder-32b>>"
export GENERALIST_AGENT_MODEL="<<FILL: model id your gateway serves>>"
# EMBEDDING_* only matter when SEARCH_BACKEND=semantic:
export EMBEDDING_BASE_URL="${LLM_BASE_URL}"   # change if embeddings live elsewhere
export EMBEDDING_MODEL="jina-embeddings-v4"   # must return >= 512 dimensions

# ── External managed Postgres (pgvector) ─────────────────────────────────────
# Prerequisite: the pgvector EXTENSION must be installed on this DB and the
# migration role able to run CREATE EXTENSION — see AIRGAP.html "External
# Postgres Prerequisites". EXTERNAL_DB_SECRET is the k8s Secret holding the
# password (key: password).
export EXTERNAL_DB_HOST="<<FILL: e.g. pgvector.corp.internal>>"
export EXTERNAL_DB_SECRET="skynet-db-password"

# ── NetworkPolicy egress allowlists ──────────────────────────────────────────
# Exact internal CIDRs. An empty allowlist renders 0.0.0.0/0 (NOT air-gapped),
# so fill each. DB_EGRESS_CIDR is REQUIRED for an external DB or the pool and the
# migration Job cannot reach it.
export IDP_EGRESS_CIDR="<<FILL: IdP/OIDC subnet, e.g. 10.0.6.0/24>>"
export LLM_EGRESS_CIDR="<<FILL: LLM gateway subnet, e.g. 10.0.5.0/24>>"
export EMBEDDING_EGRESS_CIDR="${LLM_EGRESS_CIDR}"   # set separately if it differs
export DB_EGRESS_CIDR="<<FILL: managed Postgres subnet, e.g. 10.0.4.0/24>>"

# ── Secret names (defaults are fine; values are created separately, below) ───
export BACKEND_SECRET="skynet-backend-secrets"
export FRONTEND_SECRET="skynet-frontend-secrets"

# ── Optional: private CA for internal TLS (IdP / LLM / DB) ────────────────────
# Leave blank to skip. If set, create a Secret of this name holding the CA file.
export INTERNAL_CA_SECRET=""
export INTERNAL_CA_FILENAME="ca-bundle.pem"

# ── Optional: Active Directory username autocomplete in the admin tab ─────────
# Leave LDAP_EGRESS_CIDR blank to keep the DB-only NullDirectoryClient fallback.
# When enabling, also set the AD_LDAP_* env in the generated values + add
# AD_LDAP_BIND_PASSWORD to the backend Secret (see AIRGAP.html "LDAP").
export LDAP_EGRESS_CIDR=""
export LDAP_EGRESS_PORT="636"

# ─────────────────────────────────────────────────────────────────────────────
# Secrets — create these in the cluster BEFORE `install`. Generate
# BACKEND_AUTH_SECRET ONCE and reuse the identical value in both Secrets, or
# every admin API call silently 401s. Substitute your own values / secret store.
#
#   BACKEND_AUTH_SECRET="$(openssl rand -base64 32)"
#
#   kubectl -n "$NAMESPACE" create secret docker-registry "$PULL_SECRET" \
#     --docker-server="<<registry host>>" \
#     --docker-username="<<user>>" --docker-password="<<token>>"
#
#   kubectl -n "$NAMESPACE" create secret generic "$EXTERNAL_DB_SECRET" \
#     --from-literal=password="<<db password>>"
#
#   kubectl -n "$NAMESPACE" create secret generic "$BACKEND_SECRET" \
#     --from-literal=OPENAI_API_KEY="<<gateway token, or 'not-needed' if unauthenticated>>" \
#     --from-literal=BACKEND_AUTH_SECRET="$BACKEND_AUTH_SECRET"
#
#   kubectl -n "$NAMESPACE" create secret generic "$FRONTEND_SECRET" \
#     --from-literal=AUTH_SECRET="$(openssl rand -base64 32)" \
#     --from-literal=AUTH_SSO_CLIENT_SECRET="<<OIDC client secret>>" \
#     --from-literal=BACKEND_AUTH_SECRET="$BACKEND_AUTH_SECRET"
# ─────────────────────────────────────────────────────────────────────────────
